# ============================================
# ФАЙЛ: .replit
# НАЗНАЧЕНИЕ: Конфигурация запуска проекта на платформе Replit
# ============================================

# БЛОК 1: ТОЧКА ВХОДА В ПРОГРАММУ
# Определяет, какой файл будет запущен при старте
entrypoint = "main.py"

# БЛОК 2: ПОДКЛЮЧЕНИЕ ЯЗЫКА ПРОГРАММИРОВАНИЯ
# Указывает модули (интерпретаторы) для проекта
modules = ["python-3.11"]


# ============================================
# БЛОК 3: СИСТЕМНЫЕ ЗАВИСИМОСТИ (NIX)
# Настройка окружения через пакетный менеджер Nix
# ============================================
[nix]
# Канал Nixpkgs с фиксированной версией пакетов
channel = "stable-25_05"

# Список необходимых системных пакетов (устанавливаются автоматически)
packages = [
    "cairo",                # Для работы с 2D-графикой (необходим matplotlib/seaborn)
    "ffmpeg-full",          # Для обработки видео/аудио (полная версия)
    "freetype",             # Для работы со шрифтами
    "ghostscript",          # Для работы с PDF/PostScript
    "glibcLocales",         # Локали (поддержка языков и кодировок)
    "gobject-introspection", # Для взаимодействия с GLib/GObject
    "gtk3",                 # Для GUI (графический интерфейс)
    "pkg-config",           # Утилита для настройки библиотек
    "qhull",                # Вычислительная геометрия (для 3D-графики)
    "tcl",                  # Язык Tcl (может требоваться некоторыми библиотеками)
    "tk"                    # Библиотека Tk (для GUI)
]


# ============================================
# БЛОК 4: ТЕСТИРОВАНИЕ
# Настройка юнит-тестов (если используются)
# ============================================
[unitTest]
language = "python3"  # Язык для тестов


# ============================================
# БЛОК 5: ИМПОРТ ИЗ GITHUB
# Настройка импорта проекта из GitHub
# ============================================
[gitHubImport]
requiredFiles = [".replit", "replit.nix"]  # Файлы, обязательные для импорта


# ============================================
# БЛОК 6: РАЗВЁРТЫВАНИЕ (DEPLOYMENT)
# Настройки публикации проекта
# ============================================
[deployment]
# Команды для запуска приложения при деплое
run = ["python3", "main.py"]

# Целевая платформа развёртывания (Google Cloud Run)
deploymentTarget = "cloudrun"


# ============================================
# БЛОК 7: РАСШИРЕННЫЕ НАСТРОЙКИ
# ============================================
[agent]
expertMode = true  # Включает экспертный режим для агента Replit

# ============================================
# БЛОК 8: ПОЛЬЗОВАТЕЛЬСКОЕ ОКРУЖЕНИЕ
# Настройки для пользовательского доступа
# ============================================
[userenv]
# Пустой блок (резерв для будущих настроек)

[userenv.shared]
# Пустой блок (для общих окружений между пользователями)